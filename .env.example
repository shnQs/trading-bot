# Binance API credentials
# Get testnet keys from: https://testnet.binance.vision/
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_SECRET_KEY=your_testnet_secret_key_here

# Set to false and use live keys to trade real money
BINANCE_TESTNET=true

# Comma-separated trading pairs
TRADING_PAIRS=["BTCUSDT","ETHUSDT","BNBUSDT"]

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/trading_bot.db

# Strategy parameters
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
EMA_FAST=9
EMA_SLOW=21
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
CANDLE_INTERVAL=15m

# Risk management
RISK_PER_TRADE_PCT=1.0
MAX_OPEN_TRADES=3
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
DAILY_LOSS_LIMIT_PCT=3.0

# Bot behaviour — false means bot loads and evaluates signals but does NOT place orders
BOT_ENABLED=false
